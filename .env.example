# Supabase — OPTIONAL. Without these, the site runs on the static data in
# src/data/ (works/laboratory/contact from files, admin panel disabled).
#
# These are NEXT_PUBLIC_ so they are inlined into the client bundle at BUILD
# time and are visible to anyone. Only ever put PUBLIC-safe values here:
# the "publishable" (anon) key is designed to ship in the browser; all writes
# are gated by Supabase row-level-security to the admin user below.
#
# Copy to .env.local for local dev. In production these are set via the Helm
# chart / CI build args (see docs/deployment/CONTEXT.md).

NEXT_PUBLIC_SUPABASE_URL=https://ynwirdxburfksvymxixq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xDRhzzWbBMMQmegTchMiOw_avgKzOuX
NEXT_PUBLIC_ADMIN_EMAIL=hupplegend2@gmail.com
